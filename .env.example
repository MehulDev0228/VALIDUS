# Gemini (required for full validation pipeline — multi-agent + judge)
GEMINI_API_KEY=

# Optional model id (defaults to gemini-1.5-flash)
# Examples: gemini-1.5-flash, gemini-1.5-pro, gemini-2.0-flash
GEMINI_MODEL=

# Optional: persist founder memory elsewhere (default ./data/founder-memory/)
# FOUNDER_MEMORY_DIR=

# Internal observability dashboard — comma-separated sign-in emails (server-only Route)
# FV_INTERNAL_OBS_EMAILS=you@yourdomain.com

# Optional: salt product event pseudonyms / change per environment
# PRODUCT_INTEL_PEPPER=

# Optional: custom dir for append-only JSONL (default ./data/product-intelligence/)
# PRODUCT_INTEL_DIR=

# Private alpha waitlist — comma-separated invite codes; leave empty to allow open signups from /alpha only with email
# FV_ALPHA_INVITE_CODES=

# NextAuth, Stripe, Redis, etc. — add your existing secrets as needed.
