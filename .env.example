# Gemini (required for full validation pipeline — multi-agent + judge)
GEMINI_API_KEY=

# Optional model id (defaults to gemini-1.5-flash)
# Examples: gemini-1.5-flash, gemini-1.5-pro, gemini-2.0-flash
GEMINI_MODEL=

# Supabase Auth + Postgres (browser + server sessions)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Upstash Redis — required in production for daily memo limits (optional in development)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# App URL — used for Stripe redirects, sitemap, OG metadata
# NEXT_PUBLIC_APP_URL=https://verdikt.co

# Stripe (billing + webhook → entitlements + profiles.plan)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_ID_SUBSCRIPTION=
# STRIPE_PRICE_ID_TEAM=
# STRIPE_PRICE_ID_ONEOFF=

# Vercel Cron: protect /api/cron/weekly-digest (Authorization: Bearer …)
# CRON_SECRET=
# WEEKLY_DIGEST_TO_EMAIL=ops@yourdomain.com

# Transactional email (Resend)
# RESEND_API_KEY=
# RESEND_FROM_EMAIL="VERDIKT <notifications@yourdomain.com>"

# Error tracking (optional — enables instrumentation.ts)
# SENTRY_DSN=

# Optional: persist founder memory elsewhere (default ./data/founder-memory/)
# FOUNDER_MEMORY_DIR=

# Internal observability dashboard — comma-separated sign-in emails (server-only Route)
# FV_INTERNAL_OBS_EMAILS=you@yourdomain.com

# Optional: salt product event pseudonyms / change per environment
# PRODUCT_INTEL_PEPPER=

# Optional: custom dir for append-only JSONL (default ./data/product-intelligence/)
# PRODUCT_INTEL_DIR=

# Private alpha waitlist — comma-separated invite codes; leave empty to allow open signups from /alpha only with email
# FV_ALPHA_INVITE_CODES=
